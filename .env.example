# =============================================================
# FIRE DOG × YUTH CONFLUENCE AUTO-TRADE — ENV TEMPLATE
# =============================================================
# Copy these into Railway → Service → Variables. Never commit real values.

# --- Exchange Credentials ----------------------------------------------------
# Bitunix (live primary). Create with: read+trade+bot, NO withdrawal, IP whitelist Railway static IP.
BITUNIX_API_KEY=
BITUNIX_API_SECRET=
BITUNIX_PAPER_MODE=true

# Pionex (demo + read-only fallback). Create with: read+trade+bot, NO withdrawal, IP whitelist.
PIONEX_API_KEY=
PIONEX_API_SECRET=
PIONEX_PAPER_MODE=true

# Binance Spot (RUNNER child hold only — VPN required for HK).
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_SPOT_ENABLED=false

# --- Fire Dog Screener Scraper ----------------------------------------------
FIREDOG_BASE_URL=https://web-production-d254c.up.railway.app
FIREDOG_USERNAME=MMT
FIREDOG_PASSWORD=88888888

# --- Master Switches --------------------------------------------------------
TRADING_ENABLED=false        # global kill switch — must be true to place real orders
KILL_SWITCH=false            # daily P&L kill, auto-set by risk engine
PAPER_MODE_DEFAULT=true      # all new strategies default to paper

# --- Risk Limits ------------------------------------------------------------
MAX_LEVERAGE=10
MAX_CONCURRENT_TRADES=10
DAILY_LOSS_LIMIT_PCT=3       # halt all new entries if equity drops 3% intraday
RISK_PCT_PER_PARENT=1        # 1% equity at risk per parent setup (split into 4 children)

# --- Confluence Thresholds --------------------------------------------------
FIREDOG_SHORT_MIN=80         # reject universe if short_score < 80
FIREDOG_LONG_RUNNER_MIN=70   # skip RUNNER child if long_score < 70
SMC_MIN_SCORE=2              # require >= 2 SMC structures (FVG/OB/BOS)
QIMEN_WEIGHT=0.15            # Qimen contribution to total confluence score
SPREAD_MAX_BPS=30            # reject trade if spread > 30 bps (0.30%)
DEPTH_MIN_USD=20000          # reject if top-of-book depth < $20k

# --- Maker-First Execution --------------------------------------------------
MAKER_FIRST=true             # post limit, fall back to IOC taker after timeout
MAKER_TIMEOUT_MS=8000        # 8s wait for fill before falling back
SCALPER_RR=1.5               # Yuth used 1.2 — bumped to cover fees+slippage
SNIPER_RR=2
SWING_RR=4
RUNNER_RR=8

# --- Qimen Sidecar ----------------------------------------------------------
QIMEN_SIDECAR_URL=http://localhost:8765
QIMEN_ENABLED=true

# --- Discord / Telegram Alerts ----------------------------------------------
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
